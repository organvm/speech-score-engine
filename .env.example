# Speech-score engine — local development environment.
# Copy to .env and fill in. Per blueprint §10, all required vars are validated
# at process start by packages/config and fail fast if missing.

NODE_ENV=development

WEB_PORT=3000
API_PORT=4000

DATABASE_URL=postgres://sse:sse@localhost:5432/speech_score_engine

REDIS_URL=redis://localhost:6379

OBJECT_STORAGE_BUCKET=sse-local
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minio
OBJECT_STORAGE_SECRET_KEY=miniosecret

AUTH_SESSION_SECRET=dev-only-change-me

VOICE_PROVIDER_ID=mock
VOICE_PROVIDER_API_KEY=dev-only-change-me

APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
PUBLIC_SHARE_BASE_URL=http://localhost:3000/share

LOG_LEVEL=info
